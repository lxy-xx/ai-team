# Core
AI_TEAM_PORT=8787
AI_TEAM_HOST=0.0.0.0
AI_TEAM_DATA_DIR=./data
AI_TEAM_AGENT_WORKSPACE_DIR=./agent-workspace
AI_TEAM_PROJECT_WORKSPACE_ROOT=./projects
AI_TEAM_WORKSPACE=.
AI_TEAM_RUNNER=mock
AI_TEAM_PROVIDER=mock
AI_TEAM_MODEL=
AI_TEAM_POLL_INTERVAL_MS=5000
AI_TEAM_FEEDBACK_SCAN_INTERVAL_MS=14400000
AI_TEAM_PUBLIC_BASE_URL=
AI_TEAM_ADMIN_TOKEN=

# Subagent runner
AI_TEAM_CODEX_BIN=codex
AI_TEAM_CODEX_MODEL=
AI_TEAM_CODEX_SANDBOX=workspace-write
AI_TEAM_CODEX_APPROVAL=never
AI_TEAM_CODEX_TIMEOUT_MS=900000

# Async Bash
AI_TEAM_ASYNC_BASH_MAX_RUNNING_PER_ROLE=8
AI_TEAM_ASYNC_BASH_MAX_RUNNING_GLOBAL=32

# Tool policy
AI_TEAM_APPROVAL_MODE=never
AI_TEAM_MAX_AUTO_TOOL_RISK=medium
AI_TEAM_TOOL_SANDBOX=workspace-write
AI_TEAM_DENIED_TOOLS=
AI_TEAM_APPROVAL_REQUIRED_TOOLS=shell.exec,workspace.write,feishu.cli,channel.reply

# Feishu / Lark websocket mode
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CLI_BIN=feishu-cli
